{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      { "source": "/", "destination": "/es/", "type": 302 },
      { "source": "/es/about", "destination": "/es/", "type": 301 },
      { "source": "/en/about", "destination": "/en/", "type": 301 },
      { "source": "/es/articles", "destination": "/es/tech", "type": 301 },
      { "source": "/en/articles", "destination": "/en/tech", "type": 301 },
      { "source": "/es/media", "destination": "/es/tech", "type": 301 },
      { "source": "/en/media", "destination": "/en/tech", "type": 301 },
      { "source": "/es/contributions", "destination": "/es/tech", "type": 301 },
      { "source": "/en/contributions", "destination": "/en/tech", "type": 301 },
      { "source": "/liderazgoafectivo", "destination": "/es/leadership", "type": 301 }
    ],
    "headers": [
      {
        "source": "**/_astro/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|eot|otf|ttf|ttc|woff|woff2|font.css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "fonts/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
