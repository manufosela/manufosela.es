rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'mjfosela@gmail.com';
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
