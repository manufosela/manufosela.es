---
import { Book } from '~/data/book';

interface Props {
  language: 'es' | 'en';
}

const { language } = Astro.props;
const bookData = Book[language];
---

<div class="book-promotion">
  <h2>{bookData.title}</h2>
  <p>{bookData.description}</p>
  <div class="book-links">
    <a href={bookData.bookLink} class="book-link" target="_blank" rel="noopener noreferrer">{bookData.bookButton}</a>
    <a href={bookData.blogLink} class="blog-link" target="_blank" rel="noopener noreferrer">{bookData.blogButton}</a>
  </div>
</div>

<style>
  .book-promotion {
    text-align: center;
    margin: 2rem 0;
    padding: 2rem;
    background: var(--primary-color);
    border-radius: 8px;
  }

  .book-promotion h2 {
    color: var(--background-light);
    margin-bottom: 1rem;
  }

  .book-promotion p {
    color: var(--background-light);
  }

  .book-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1rem;
  }

  .book-link,
  .blog-link {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background-color: var(--color-text-light);
    color: var(--background-light);
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .book-link:hover,
  .blog-link:hover {
    background-color: var(--active-color);
    color: var(--background-light);
  }

  body[data-theme='dark'] .book-promotion {
    background: rgba(68, 170, 204, 0.15);
  }

  body[data-theme='dark'] .book-promotion h2 {
    color: var(--color-text-light);
  }

  body[data-theme='dark'] .book-promotion p {
    color: var(--color-text-light);
  }

  @media screen and (max-width: 991px) {
    .book-promotion {
      padding: 1.5rem 1rem;
      margin: 1rem 0;
    }

    .book-links {
      flex-direction: column;
      align-items: center;
    }

    .book-link,
    .blog-link {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }
  }
</style>
