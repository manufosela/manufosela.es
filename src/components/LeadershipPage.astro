---
import { leadershipData } from '~/data/leadership';

interface Props {
  language: 'es' | 'en';
}

const { language } = Astro.props;
const d = leadershipData[language];

const icons = {
  terminal: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16v12H4z"/><path d="m8 10 2 2-2 2"/><path d="M12 14h4"/></svg>',
  chart: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 16l4-4 4 2 5-6"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="m3.5 6.5 8.5 6 8.5-6"/></svg>'
};
---

<div class="leadership-page">

  <!-- Hero Libro -->
  <section class="hero-libro" aria-label={d.heroBadge}>
    <div class="hero-libro__text">
      <span class="hero-libro__badge">{d.heroBadge}</span>
      <h1 class="hero-libro__title">
        {d.heroTitle} <span class="hero-libro__accent">{d.heroTitleAccent}</span>
      </h1>
      <p class="hero-libro__desc">{d.heroDescription}</p>
      <div class="hero-libro__actions">
        <a href={d.buyLink} class="hero-libro__btn hero-libro__btn--primary" target="_blank" rel="noopener noreferrer">
          {d.buyButton}
        </a>
        <a href={d.detailsLink} class="hero-libro__btn hero-libro__btn--ghost" target="_blank" rel="noopener noreferrer">
          {d.detailsButton}
        </a>
      </div>
      <p class="hero-libro__editorial">{d.editorialNote}</p>
    </div>
    <div class="hero-libro__cover">
      <img
        src={d.bookCover}
        alt={d.bookAlt}
        width="400"
        height="580"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- Manifesto -->
  <section class="manifesto" aria-label={d.manifestoLabel}>
    <div class="manifesto__line" aria-hidden="true"></div>
    <span class="u-label">{d.manifestoLabel}</span>
    <blockquote class="manifesto__quote">
      &ldquo;{d.manifesto.split(d.manifestoAccent)[0]}<span class="manifesto__accent">{d.manifestoAccent}</span>{d.manifesto.split(d.manifestoAccent)[1]}&rdquo;
    </blockquote>
  </section>

  <!-- Comunidad -->
  <section class="community" aria-label={d.communityTitle}>
    <div class="community__card">
      <div class="community__glow" aria-hidden="true"></div>
      <div class="community__inner">
        <div class="community__badge">
          <span class="community__dot" aria-hidden="true"></span>
          <span class="u-label u-label--accent">{d.communityStatus}</span>
        </div>
        <h2 class="community__title">{d.communityTitle}</h2>
        <p class="community__desc">{d.communityDescription}</p>
        <a href={d.communityLink} class="community__cta" target="_blank" rel="noopener noreferrer">
          {d.communityButton}
        </a>
      </div>
    </div>
  </section>

  <!-- Insights Bento -->
  <section class="insights u-bento" aria-label="Insights">
    {d.insightsItems.map((item) => (
      <div class="insights__item u-bento__item">
        <span class="insights__icon" aria-hidden="true" set:html={icons[item.icon]} />
        <h3 class="insights__title">{item.title}</h3>
        <p class="insights__desc">{item.description}</p>
      </div>
    ))}
  </section>

</div>

<style>
  .leadership-page {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 8vh, 5rem);
    padding-block: clamp(2rem, 6vh, 4rem);
  }

  /* Hero Libro */
  .hero-libro {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .hero-libro__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--primary-fixed-dim);
    margin-bottom: 1rem;
  }

  .hero-libro__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--on-surface);
    margin-bottom: 1rem;
  }
  .hero-libro__accent {
    background: linear-gradient(135deg, var(--primary-fixed-dim), var(--primary-container));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-libro__desc {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    line-height: 1.6;
    color: var(--on-surface-variant);
    max-width: 28rem;
    margin-bottom: 1.5rem;
  }

  .hero-libro__editorial {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--on-surface-variant);
    margin-top: 1rem;
  }

  .hero-libro__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-libro__btn {
    display: block;
    text-align: center;
    padding: 1rem;
    border-radius: 0.75rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 200ms var(--ease-3);
  }
  .hero-libro__btn:active { transform: scale(0.98); }
  .hero-libro__btn--primary {
    background-color: var(--primary-container);
    color: var(--on-primary-container);
  }
  .hero-libro__btn--ghost {
    background: transparent;
    color: var(--on-surface);
    border: 1px solid color-mix(in srgb, var(--outline-variant) 15%, transparent);
  }
  .hero-libro__btn:hover { opacity: 0.85; }

  .hero-libro__cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--surface-container-low);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .hero-libro__cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--surface-container-lowest), transparent);
    opacity: 0.6;
  }
  .hero-libro__cover img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    height: auto;
    max-height: 400px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgb(0 0 0 / 50%));
  }

  @media (min-width: 1024px) {
    .hero-libro {
      flex-direction: row;
      align-items: center;
    }
    .hero-libro__text { flex: 6; }
    .hero-libro__cover { flex: 4; min-height: 28rem; }
    .hero-libro__actions {
      flex-direction: row;
      gap: 1rem;
    }
    .hero-libro__btn {
      width: auto;
      padding: 1rem 2rem;
    }
  }

  /* Manifesto */
  .manifesto {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    padding-block: clamp(2.5rem, 6vh, 4rem);
    background-color: var(--surface-container-lowest);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .manifesto__line {
    width: 3rem;
    height: 1px;
    background-color: color-mix(in srgb, var(--primary-container) 40%, transparent);
    margin-bottom: 1.5rem;
  }

  .manifesto__quote {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: var(--on-surface);
    max-width: 42rem;
    margin-top: 1.5rem;
  }

  .manifesto__accent {
    color: var(--primary-fixed-dim);
  }

  /* Community */
  .community {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .community__card {
    position: relative;
    background-color: var(--surface-container-low);
    border-radius: 1rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--outline-variant) 5%, transparent);
  }

  .community__glow {
    position: absolute;
    right: -2.5rem;
    bottom: -2.5rem;
    width: 10rem;
    height: 10rem;
    background-color: color-mix(in srgb, var(--primary-container) 5%, transparent);
    filter: blur(3rem);
    border-radius: 50%;
  }

  .community__inner {
    position: relative;
    z-index: 1;
  }

  .community__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .community__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: var(--primary-fixed-dim);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .community__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--on-surface);
  }

  .community__desc {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    line-height: 1.6;
    color: var(--on-surface-variant);
    max-width: 32rem;
    margin-bottom: 2rem;
  }

  .community__cta {
    display: block;
    position: relative;
    z-index: 1;
    text-align: center;
    width: 100%;
    padding: 1rem;
    border-radius: 0.75rem;
    background-color: color-mix(in srgb, var(--on-surface) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary-container) 20%, transparent);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--primary-container);
    text-decoration: none;
    transition: background-color 200ms var(--ease-3);
  }
  .community__cta:hover {
    background-color: color-mix(in srgb, var(--primary-container) 10%, transparent);
  }

  /* Insights Bento */
  .insights {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
    grid-template-columns: repeat(3, 1fr);
  }

  .insights__item {
    grid-column: span 1;
  }

  .insights__icon {
    display: inline-flex;
    width: 1.5rem;
    height: 1.5rem;
    color: var(--primary-container);
    margin-bottom: 1rem;
  }
  .insights__icon :global(svg) { width: 100%; height: 100%; }

  .insights__title {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--on-surface);
    margin-bottom: 0.375rem;
  }

  .insights__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--on-surface-variant);
  }

  @media (max-width: 640px) {
    .insights {
      grid-template-columns: 1fr 1fr;
    }
    .insights__item:first-child {
      grid-column: span 2;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-libro__btn,
    .community__cta { transition: none; }
  }
</style>
