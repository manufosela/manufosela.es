---
import { leadershipData } from '~/data/leadership';
import { fetchPhotos } from '~/utils/fetchPhotos';
import { mediaData } from '~/data/media';
import PhotosRehydrator from '~/components/PhotosRehydrator.astro';

interface Props {
  language: 'es' | 'en';
}

const { language } = Astro.props;
const leadershipPhotos = await fetchPhotos('leadership');
const d = leadershipData[language];

const talksKey = language === 'es' ? 'Charlas' : 'Talks';
const media = mediaData[language];
const talks = media[talksKey];
const latestTalkYear = talks ? Object.keys(talks).sort().reverse()[0] : null;
const latestTalks = latestTalkYear ? talks[latestTalkYear]?.slice(0, 3) || [] : [];

---

<script is:inline type="module" src="https://esm.sh/@manufosela/photo-collage@1.1.0"></script>

<div class="leadership-page">

  <!-- Hero Libro -->
  <section class="hero-libro" aria-label={d.heroBadge}>
    <div class="hero-libro__text">
      <span class="hero-libro__badge">{d.heroBadge}</span>
      <h1 class="hero-libro__title">
        {d.heroTitle} <span class="hero-libro__accent">{d.heroTitleAccent}</span>
      </h1>
      <p class="hero-libro__desc">{d.heroDescription}</p>
      <div class="hero-libro__actions">
        <a href={d.buyLink} class="hero-libro__btn hero-libro__btn--primary" target="_blank" rel="noopener noreferrer">
          {d.buyButton}
        </a>
        <a href={d.detailsLink} class="hero-libro__btn hero-libro__btn--ghost" target="_blank" rel="noopener noreferrer">
          {d.detailsButton}
        </a>
      </div>
      <p class="hero-libro__editorial">{d.editorialNote}</p>
    </div>
    <div class="hero-libro__cover">
      <img
        src={d.bookCover}
        alt={d.bookAlt}
        width="400"
        height="580"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- Manifesto -->
  <section class="manifesto" aria-label={d.manifestoLabel}>
    <div class="manifesto__line" aria-hidden="true"></div>
    <span class="u-label">{d.manifestoLabel}</span>
    <blockquote class="manifesto__quote">
      &ldquo;{d.manifesto.split(d.manifestoAccent)[0]}<span class="manifesto__accent">{d.manifestoAccent}</span>{d.manifesto.split(d.manifestoAccent)[1]}&rdquo;
    </blockquote>
  </section>

  <!-- Comunidad -->
  <section class="community" aria-label={d.communityTitle}>
    <div class="community__card">
      <div class="community__glow" aria-hidden="true"></div>
      <div class="community__inner">
        <div class="community__badge">
          <span class="community__dot" aria-hidden="true"></span>
          <span class="u-label u-label--accent">{d.communityStatus}</span>
        </div>
        <h2 class="community__title">{d.communityTitle}</h2>
        <p class="community__desc">{d.communityDescription}</p>
        <a href={d.communityLink} class="community__cta" target="_blank" rel="noopener noreferrer">
          {d.communityButton}
        </a>
      </div>
    </div>
  </section>

  <!-- En acción — photo-collage -->
  {leadershipPhotos.length > 0 && (
    <section class="en-accion" id="en-accion-section" aria-label={language === 'es' ? 'En acción' : 'In action'}>
      <h2 class="en-accion__title">{language === 'es' ? 'En acción' : 'In action'}</h2>
      <div class="en-accion__wrap">
        <photo-collage
          width="800"
          height="400"
          cols={Math.min(4, leadershipPhotos.length)}
          rows={Math.max(1, Math.ceil(leadershipPhotos.length / 4))}
          max-rotation="12"
          polaroid
          shuffle
          zoomable
        >
          {leadershipPhotos.map((photo) => (
            <img src={photo.url} alt={photo.alt} />
          ))}
        </photo-collage>
      </div>
      <PhotosRehydrator section="leadership" target="#en-accion-section" mode="collage" />
    </section>
  )}

  <!-- Charlas sobre liderazgo -->
  {latestTalks.length > 0 && (
    <section class="lead-talks" aria-label={d.talksTitle}>
      <div class="lead-talks__header">
        <h2 class="lead-talks__title">{d.talksTitle}</h2>
        <a class="lead-talks__viewall" href={`/${language}/leadership/talks`}>{d.talksViewAll} →</a>
      </div>
      <div class="lead-talks__list">
        {latestTalks.map((talk) => (
          <a href={talk.link} class="lead-talks__item" target="_blank" rel="noopener noreferrer">
            <div class="lead-talks__play">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7Z"/></svg>
            </div>
            <span class="lead-talks__name">{talk.title}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="lead-forms-wrap">
  <!-- Consultas -->
  <div class="lead-form" aria-label={d.consultasTitle}>
    <h2 class="lead-form__title">{d.consultasTitle}</h2>
    <p class="lead-form__desc">{d.consultasDesc}</p>
    <form action="https://formspree.io/f/mrbqjrkv" method="POST" class="lead-form__form">
      <input type="hidden" name="_subject" value="Consulta desde manufosela.es — Liderazgo" />
      <div class="lead-form__field">
        <input type="text" name="name" placeholder={language === 'es' ? 'Tu nombre' : 'Your name'} required />
      </div>
      <div class="lead-form__field">
        <input type="email" name="email" placeholder="email" required />
      </div>
      <div class="lead-form__field">
        <textarea name="message" rows="3" placeholder={d.consultasPlaceholder} required></textarea>
      </div>
      <div style="position:absolute;left:-9999px" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <button type="submit" class="lead-form__btn">{d.consultasButton}</button>
    </form>
  </div>

  <!-- Contacto -->
  <div class="lead-form" aria-label={d.contactTitle}>
    <h2 class="lead-form__title">{d.contactTitle}</h2>
    <p class="lead-form__desc">{d.contactDesc}</p>
    <form action="https://formspree.io/f/mrbqjrkv" method="POST" class="lead-form__form">
      <input type="hidden" name="_subject" value="Contacto desde manufosela.es — Liderazgo" />
      <div class="lead-form__field">
        <input type="text" name="name" placeholder={language === 'es' ? 'Tu nombre' : 'Your name'} required />
      </div>
      <div class="lead-form__field">
        <input type="email" name="email" placeholder="email" required />
      </div>
      <div class="lead-form__field">
        <textarea name="message" rows="3" placeholder={d.contactPlaceholder} required></textarea>
      </div>
      <div style="position:absolute;left:-9999px" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <button type="submit" class="lead-form__btn">{d.contactButton}</button>
    </form>
  </div>
  </section>

</div>

<style>
  .leadership-page {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 8vh, 5rem);
    padding-block: clamp(2rem, 6vh, 4rem);
  }

  .leadership-page > section,
  .leadership-page > .lead-forms-wrap {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  /* Hero Libro */
  .hero-libro {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .hero-libro__badge {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--primary-fixed-dim);
    margin-bottom: 1rem;
  }

  .hero-libro__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--on-surface);
    margin-bottom: 1rem;
  }
  .hero-libro__accent {
    background: linear-gradient(135deg, var(--primary-fixed-dim), var(--primary-container));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-libro__desc {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    line-height: 1.6;
    color: var(--on-surface-variant);
    max-width: 28rem;
    margin-bottom: 1.5rem;
  }

  .hero-libro__editorial {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--on-surface-variant);
    margin-top: 1rem;
  }

  .hero-libro__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-libro__btn {
    display: block;
    text-align: center;
    padding: 1rem;
    border-radius: 0.75rem;
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 200ms var(--ease-3);
  }
  .hero-libro__btn:active { transform: scale(0.98); }
  .hero-libro__btn--primary {
    background-color: var(--primary-container);
    color: var(--on-primary-container);
  }
  .hero-libro__btn--ghost {
    background: transparent;
    color: var(--on-surface);
    border: 1px solid color-mix(in srgb, var(--outline-variant) 15%, transparent);
  }
  .hero-libro__btn:hover { opacity: 0.85; }

  .hero-libro__cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--surface-container-low);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .hero-libro__cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--surface-container-lowest), transparent);
    opacity: 0.6;
  }
  .hero-libro__cover img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    height: auto;
    max-height: 400px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgb(0 0 0 / 50%));
  }

  @media (min-width: 1024px) {
    .hero-libro {
      flex-direction: row;
      align-items: center;
    }
    .hero-libro__text { flex: 6; }
    .hero-libro__cover { flex: 4; min-height: 28rem; }
    .hero-libro__actions {
      flex-direction: row;
      gap: 1rem;
    }
    .hero-libro__btn {
      width: auto;
      padding: 1rem 2rem;
    }
  }

  /* Manifesto */
  .manifesto {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    padding-block: clamp(2.5rem, 6vh, 4rem);
    background-color: var(--surface-container-lowest);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .manifesto__line {
    width: 3rem;
    height: 1px;
    background-color: color-mix(in srgb, var(--primary-container) 40%, transparent);
    margin-bottom: 1.5rem;
  }

  .manifesto__quote {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: var(--on-surface);
    max-width: 42rem;
    margin-top: 1.5rem;
  }

  .manifesto__accent {
    color: var(--primary-fixed-dim);
  }

  /* Community */
  .community {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .community__card {
    position: relative;
    background-color: var(--surface-container-low);
    border-radius: 1rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--outline-variant) 5%, transparent);
  }

  .community__glow {
    position: absolute;
    right: -2.5rem;
    bottom: -2.5rem;
    width: 10rem;
    height: 10rem;
    background-color: color-mix(in srgb, var(--primary-container) 5%, transparent);
    filter: blur(3rem);
    border-radius: 50%;
  }

  .community__inner {
    position: relative;
    z-index: 1;
  }

  .community__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .community__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: var(--primary-fixed-dim);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .community__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--on-surface);
  }

  .community__desc {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    line-height: 1.6;
    color: var(--on-surface-variant);
    max-width: 32rem;
    margin-bottom: 2rem;
  }

  .community__cta {
    display: block;
    position: relative;
    z-index: 1;
    text-align: center;
    width: 100%;
    padding: 1rem;
    border-radius: 0.75rem;
    background-color: color-mix(in srgb, var(--on-surface) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary-container) 20%, transparent);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--primary-container);
    text-decoration: none;
    transition: background-color 200ms var(--ease-3);
  }
  .community__cta:hover {
    background-color: color-mix(in srgb, var(--primary-container) 10%, transparent);
  }

  /* En acción (photo-collage) */
  .en-accion__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--on-surface);
    margin-bottom: 1.5rem;
  }
  .en-accion__wrap {
    width: 100%;
    overflow-x: auto;
    display: flex;
    justify-content: center;
    padding-block: 1rem;
    scrollbar-width: thin;
  }
  .en-accion photo-collage {
    display: block;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .en-accion__wrap { justify-content: flex-start; padding-inline: 0; }
  }

  /* Forms side-by-side on desktop */
  .lead-forms-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .lead-forms-wrap {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  /* Charlas de liderazgo (preview) */
  .lead-talks__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .lead-talks__title {
    font-family: 'Manrope', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--on-surface);
  }
  .lead-talks__viewall {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary-fixed-dim);
    text-decoration: none;
  }
  .lead-talks__viewall:hover { text-decoration: underline; }
  .lead-talks__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .lead-talks__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background-color: var(--surface-container-low);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 200ms var(--ease-3);
  }
  .lead-talks__item:hover { background-color: var(--surface-container-high); }
  .lead-talks__play {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.375rem;
    background-color: var(--surface-container-high);
    color: var(--primary-container);
  }
  .lead-talks__play svg { width: 0.875rem; height: 0.875rem; }
  .lead-talks__name {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface);
  }

  /* Forms */
  .lead-form__title {
    font-family: 'Manrope', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--on-surface);
    margin-bottom: 0.375rem;
  }
  .lead-form__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--on-surface-variant);
    margin-bottom: 1.5rem;
  }
  .lead-form__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 36rem;
    position: relative;
  }
  .lead-form__field input,
  .lead-form__field textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    background-color: var(--surface-container-lowest);
    border: 0;
    border-radius: 0.5rem;
    color: var(--on-surface);
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    outline: none;
    transition: box-shadow 200ms var(--ease-3);
  }
  .lead-form__field input::placeholder,
  .lead-form__field textarea::placeholder {
    color: var(--outline-variant);
  }
  .lead-form__field input:focus,
  .lead-form__field textarea:focus {
    box-shadow: inset 0 0 0 1px var(--primary-fixed-dim);
  }
  .lead-form__field textarea { resize: vertical; }
  .lead-form__btn {
    padding: 0.875rem 1.5rem;
    background-color: var(--primary-container);
    color: var(--on-primary-container);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    border: 0;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: opacity 200ms var(--ease-3);
    align-self: flex-start;
  }
  .lead-form__btn:hover { opacity: 0.85; }

  @media (prefers-reduced-motion: reduce) {
    .hero-libro__btn,
    .community__cta,
    .lead-talks__item,
    .lead-form__btn { transition: none; }
  }
</style>
