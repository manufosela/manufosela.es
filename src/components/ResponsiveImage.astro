---
interface Props {
  imagePath: string;
  description: string;
}

const { imagePath, description } = Astro.props;

// Asegurarnos de que la ruta comience con /
const basePath = imagePath.startsWith('/') ? imagePath : `/${imagePath}`;
---

<figure class="responsive-image-container">
  <picture>
    <source srcset={`${basePath}1280.webp`} media="(min-width: 1280px)" type="image/webp" />
    <source srcset={`${basePath}768.webp`} media="(min-width: 768px)" type="image/webp" />
    <source srcset={`${basePath}480.webp`} media="(min-width: 480px)" type="image/webp" />
    <img
      src={`${basePath}320.webp`}
      srcset={`${basePath}320.webp 320w, ${basePath}460.webp 460w, ${basePath}480.webp 480w, ${basePath}768.webp 768w, ${basePath}1280.webp 1280w`}
      sizes="(max-width: 991px) 100vw, 50vw"
      alt={description}
      class="responsive-image"
      width="480"
      height="480"
      loading="eager"
      fetchpriority="high"
    />
  </picture>
  <figcaption>{description}</figcaption>
</figure>

<style>
  .responsive-image-container {
    width: 50%;
    text-align: center;
    margin: 0;
    padding: 2rem;
    position: sticky;
    top: 0;
  }

  .responsive-image {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  figcaption {
    margin-top: 1rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  @media (max-width: 991px) {
    .responsive-image-container {
      width: 100%;
      padding: 1rem;
      position: relative;
    }
  }
</style>
