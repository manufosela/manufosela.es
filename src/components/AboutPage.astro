---
import { aboutData, aboutDesc } from '~/data/about';
import { ManuFosela } from '~/data/index';

interface Props {
  language: 'es' | 'en';
}

const { language } = Astro.props;
const about = aboutData[language];
const person = ManuFosela[language];
const portraitAlt = aboutDesc[language];
---

<div class="about-page">

  <!-- Hero with portrait -->
  <section class="about-hero">
    <div class="about-hero__portrait">
      <img
        src="/images/manufosela/manufosela1280.webp"
        srcset="/images/manufosela/manufosela320.webp 320w,
                /images/manufosela/manufosela460.webp 460w,
                /images/manufosela/manufosela480.webp 480w,
                /images/manufosela/manufosela768.webp 768w,
                /images/manufosela/manufosela1280.webp 1280w"
        sizes="(min-width: 1024px) 40vw, 100vw"
        alt={portraitAlt}
        width="1280"
        height="1600"
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="about-hero__text">
      <span class="u-label u-label--accent">{language === 'es' ? 'Sobre mí' : 'About me'}</span>
      <h1 class="about-hero__title">{person.name}</h1>
      <p class="about-hero__role">Head of Engineering & CTO</p>
    </div>
  </section>

  <!-- Slides / Secciones -->
  {about.slides.map((slide, i) => (
    <section class:list={['about-section', { 'about-section--alt': i % 2 === 1 }]}>
      <h2 class="about-section__subtitle">{slide.subtitle}</h2>
      <div class="about-section__text" set:html={slide.description.replace(/\n/g, '<br>')} />
    </section>
  ))}

</div>

<style>
  .about-page {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 6vh, 4rem);
    padding-block: clamp(2rem, 6vh, 4rem);
  }

  .about-page > section {
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    max-width: 1280px;
    margin-inline: auto;
    width: 100%;
  }

  .about-hero {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  .about-hero__portrait {
    width: 100%;
    max-width: 22rem;
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: var(--surface-container-low);
  }
  .about-hero__portrait img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(1) contrast(1.15);
  }

  .about-hero__text { flex: 1; }
  .about-hero__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--on-surface);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .about-hero__role {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    color: var(--on-surface-variant);
  }

  .about-section {
    max-width: 48rem;
  }
  .about-section--alt {
    background-color: var(--surface-container-lowest);
    padding-block: clamp(2rem, 5vh, 3rem);
    border-radius: 0.75rem;
    max-width: 1280px;
  }
  .about-section__subtitle {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 800;
    color: var(--primary-fixed-dim);
    margin-bottom: 1.25rem;
  }
  .about-section__text {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.9375rem, 1.5vw, 1rem);
    line-height: 1.7;
    color: var(--on-surface-variant);
  }
  .about-section__text :global(a) {
    color: var(--primary-fixed-dim);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (min-width: 768px) {
    .about-hero {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
    .about-hero__portrait {
      flex-shrink: 0;
      max-width: 18rem;
    }
  }

  @media (min-width: 1024px) {
    .about-section {
      max-width: 48rem;
    }
    .about-section--alt {
      max-width: 1280px;
      padding-inline: clamp(3rem, 6vw, 5rem);
    }
  }
</style>
