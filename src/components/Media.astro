---
import { mediaData } from '~/data/media';

const { language } = Astro.props;

const medias = mediaData[language] || [];
const charlasKey = language === 'es' ? 'Charlas' : 'Talks';
const entrevistasKey = language === 'es' ? 'Entrevistas' : 'Interviews';
---

<div class="pagecontent">
  <div class="tabs-header" role="tablist" aria-label="Tipo de media">
    <button class="tab-button active" data-tab="0" role="tab" aria-selected="true" aria-controls="media-tabpanel-0" id="media-tab-0">{charlasKey}</button>
    <button class="tab-button" data-tab="1" role="tab" aria-selected="false" aria-controls="media-tabpanel-1" id="media-tab-1">{entrevistasKey}</button>
  </div>

  <div class="tabs-content">
    <div class="tab-panel active" data-tab="0" role="tabpanel" id="media-tabpanel-0" aria-labelledby="media-tab-0">
      {
        Object.entries(medias[charlasKey] || {})
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, items]) => (
            <div class="year-section">
              <h3 class="year-title">{year}</h3>
              <ul class="media-list">
                {items.map((media) => (
                  <li>
                    <a href={media.link} target="_blank" rel="noopener noreferrer">
                      {media.title}
                      <span class="external-link" aria-hidden="true">↗</span>
                      <span class="visually-hidden">(enlace externo)</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
      }
    </div>
    <div class="tab-panel" data-tab="1" role="tabpanel" id="media-tabpanel-1" aria-labelledby="media-tab-1">
      {
        Object.entries(medias[entrevistasKey] || {})
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, items]) => (
            <div class="year-section">
              <h3 class="year-title">{year}</h3>
              <ul class="media-list">
                {items.map((media) => (
                  <li>
                    <a href={media.link} target="_blank" rel="noopener noreferrer">
                      {media.title}
                      <span class="external-link" aria-hidden="true">↗</span>
                      <span class="visually-hidden">(enlace externo)</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
      }
    </div>
  </div>
</div>

<script>
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const tabIndex = button.getAttribute('data-tab');

      tabButtons.forEach((btn) => {
        btn.classList.remove('active');
        btn.setAttribute('aria-selected', 'false');
      });
      button.classList.add('active');
      button.setAttribute('aria-selected', 'true');

      // Update panels
      tabPanels.forEach((panel) => {
        panel.classList.remove('active');
      });
      document.querySelector<HTMLElement>(`.tab-panel[data-tab="${tabIndex}"]`)?.classList.add('active');
    });
  });
</script>

<style>
  .tabs-header {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--primary-color);
    padding-bottom: 0.5rem;
  }

  .tab-button {
    padding: 0.5rem 1rem;
    background: transparent;
    border: none;
    border-radius: 4px 4px 0 0;
    cursor: pointer;
    color: var(--color-text-light);
    font-size: 1.2rem;
    transition: all 0.2s;
    position: relative;
    font-weight: 500;
  }

  .tab-button.active {
    color: var(--active-color);
    font-weight: 700;
    background-color: transparent;
  }

  .tab-button.active::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 100%;
    height: 6px;
    background-color: var(--active-color);
    border-radius: 3px;
  }

  .tab-button:hover {
    color: var(--active-color);
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .year-section {
    margin-bottom: 2rem;
  }

  .year-title {
    color: var(--active-color);
    font-size: 1.8rem;
    margin: 1.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--active-color);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .media-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .media-list li {
    margin-bottom: 1rem;
  }

  .media-list a {
    color: var(--primary-color);
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
    cursor: pointer;
    font-size: 1.2rem;
    font-weight: 400;
  }

  .media-list a:hover {
    transform: translateX(5px);
    color: var(--active-color);
  }

  .media-list a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--primary-color);
    transition: width 0.3s ease;
  }

  .media-list a:hover::after {
    width: 100%;
  }

  .external-link {
    margin-left: 0.3rem;
    font-size: 0.9em;
    opacity: 0;
    transition: opacity 0.3s ease;
    font-weight: 400;
  }

  .media-list a:hover .external-link {
    opacity: 1;
  }

  @media screen and (max-width: 991px) {
    .tab-button {
      font-size: 1.1rem;
      padding: 0.5rem 0.8rem;
    }
    .media-list a {
      font-size: 1.1rem;
    }
    .year-title {
      font-size: 1.4rem;
    }
  }
</style>
