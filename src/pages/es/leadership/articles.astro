---
import Layout from '~/layouts/Layout.astro';
import ArticleCatalog from '~/components/ArticleCatalog.astro';
import { getAllArticles, filterByTopic } from '~/utils/fetchArticles';
import { Site } from '~/data/config';

const allArticles = await getAllArticles();
const leadershipArticles = filterByTopic(allArticles, 'leadership');
const title = `${Site.title} — Artículos Liderazgo`;
---

<Layout {title} active="leadership">
  <main>
    <ArticleCatalog title="Artículos de Liderazgo" articles={leadershipArticles} language="es" />
  </main>
</Layout>
